# SensorLLM Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and should never be committed.

# Absolute path to the data/ directory (raw sensor files, processed data, spectrograms)
SENSORLLM_DATA_ROOT=/path/to/sensorllm/data

# Absolute path to the outputs/ directory (experiment runs, checkpoints)
SENSORLLM_OUTPUT_ROOT=/path/to/sensorllm/outputs

# Weights & Biases experiment tracking
WANDB_PROJECT=sensorllm
WANDB_ENTITY=your-wandb-username

# HuggingFace model cache (optional; defaults to ~/.cache/huggingface)
HF_HOME=/path/to/hf_cache

# HuggingFace access token (required for gated models like LLaMA)
HF_TOKEN=hf_your_token_here
